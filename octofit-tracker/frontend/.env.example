# Vite environment variables for OctoFit Tracker Frontend
# Copy this file to .env.local and fill in the values

# GitHub Codespaces Configuration
# If running in GitHub Codespaces, set this to your codespace name
# This is used to build the API URL: https://$VITE_CODESPACE_NAME-8000.app.github.dev/api/...
# If not set, the app will use http://localhost:8000/api/... for local development
VITE_CODESPACE_NAME=

# Development
VITE_FRONTEND_PORT=5173
